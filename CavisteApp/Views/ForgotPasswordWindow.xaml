<Window x:Class="CavisteApp.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mot de passe oublié" Height="500" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F7F1EE">
    <StackPanel Margin="32" VerticalAlignment="Center">
        <TextBlock Text="Mot de passe oublié" FontSize="20" FontWeight="Bold"
                   Foreground="#7A1F2B" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <StackPanel x:Name="PanelDemande">
            <TextBlock Text="Email"/>
            <TextBox x:Name="ChampEmail" Padding="6" Margin="0,4,0,14"/>
            <Button Content="Envoyer le code" Padding="10,8" Background="#7A1F2B" Foreground="White"
                    BorderThickness="0" Click="BoutonEnvoyer_Click"/>
        </StackPanel>

        <StackPanel x:Name="PanelReinitialisation" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBlock Text="Code reçu par email"/>
            <TextBox x:Name="ChampCode" Padding="6" Margin="0,4,0,14"/>
            <TextBlock Text="Nouveau mot de passe"/>
            <PasswordBox x:Name="ChampNouveauMotDePasse" Padding="6" Margin="0,4,0,14"/>
            <Button Content="Réinitialiser" Padding="10,8" Background="#7A1F2B" Foreground="White"
                    BorderThickness="0" Click="BoutonReinitialiser_Click"/>
        </StackPanel>

        <TextBlock x:Name="TexteMessage" Foreground="#333333" TextWrapping="Wrap" Margin="0,14,0,0"/>
    </StackPanel>
</Window>
