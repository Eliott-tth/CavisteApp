<UserControl x:Class="CavisteApp.Views.AlerteCommandeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CavisteApp.ViewModels"
             xmlns:conv="clr-namespace:CavisteApp.Converters">

    <UserControl.Resources>
        <conv:BoolToAlertBrushConverter x:Key="AlertBrushConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:AlerteCommandeViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Vins en alerte -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Vins sous leur seuil de stock" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Rafraîchir" Command="{Binding RafraichirCommand}" Margin="16,0,0,0" Padding="10,4"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding VinsEnAlerte}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Alerte" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="14" Height="14" Fill="Crimson">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0.15" Duration="0:0:0.6"
                                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="70"/>
                    <DataGridTextColumn Header="Seuil" Binding="{Binding SeuilBas}" Width="70"/>
                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur.Nom}" Width="150"/>
                    <DataGridTemplateColumn Header="Actions" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Envoyer alerte mail"
                                            Command="{Binding DataContext.EnvoyerAlerteEmailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,2,6,2"/>
                                    <Button Content="Créer commande"
                                            Command="{Binding DataContext.CommanderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,2,0,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Commandes fournisseur -->
        <DockPanel Grid.Row="1">
            <TextBlock DockPanel.Dock="Top" Text="Commandes fournisseur" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

            <DataGrid ItemsSource="{Binding Commandes}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N°" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur.Nom}" Width="150"/>
                    <DataGridTextColumn Header="Date commande" Binding="{Binding DateCommande, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>
                    <DataGridTemplateColumn Header="Actions" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Valider"
                                            Command="{Binding DataContext.ValiderCommandeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,2,6,2"/>
                                    <Button Content="Réceptionner"
                                            Command="{Binding DataContext.ReceptionnerCommandeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,2,6,2"/>
                                    <Button Content="Supprimer"
                                            Command="{Binding DataContext.SupprimerCommandeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,2,0,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <TextBlock Grid.Row="2" Text="{Binding MessageStatut}" Margin="0,8,0,0" Foreground="DimGray"/>
    </Grid>
</UserControl>
