<UserControl x:Class="CavisteApp.Views.AccueilView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CavisteApp.ViewModels"
             xmlns:services="clr-namespace:CavisteApp.Services">

    <UserControl.DataContext>
        <vm:AccueilViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="CarteCategorie" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C2A28"/>
            <Setter Property="BorderBrush" Value="#E0D5D2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F7F1EE"/>
                    <Setter Property="BorderBrush" Value="#7A1F2B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="8">
        <TextBlock Text="Bonjour Monsieur, que souhaitez-vous faire aujourd'hui ?"
                   FontSize="24" FontWeight="Bold" Foreground="#7A1F2B" Margin="0,0,0,8"/>
        <TextBlock Text="Choisissez une catégorie ci-dessous pour commencer."
                   FontSize="14" Foreground="DimGray" Margin="0,0,0,28"/>

        <WrapPanel>
            <Button Style="{StaticResource CarteCategorie}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.TableauDeBord}"
                    Content="Tableau de bord"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Vente}"
                    Content="Vente"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Stock}"
                    Content="Stock"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Clients}"
                    Content="Clients"/>

            <Button Style="{StaticResource CarteCategorie}"
                    Visibility="{Binding EstAdministrateur, Converter={StaticResource BoolToVis}}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Fournisseurs}"
                    Content="Fournisseurs"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Visibility="{Binding EstAdministrateur, Converter={StaticResource BoolToVis}}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.AlertesCommandes}"
                    Content="Alertes &amp; Commandes"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Visibility="{Binding EstAdministrateur, Converter={StaticResource BoolToVis}}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Generation}"
                    Content="Génération"/>
            <Button Style="{StaticResource CarteCategorie}"
                    Visibility="{Binding EstAdministrateur, Converter={StaticResource BoolToVis}}"
                    Command="{Binding NaviguerCommand}"
                    CommandParameter="{x:Static services:SectionApplication.Utilisateurs}"
                    Content="Utilisateurs"/>
        </WrapPanel>
    </StackPanel>
</UserControl>
