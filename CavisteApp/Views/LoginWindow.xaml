<Window x:Class="CavisteApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cave du Sommelier - Connexion" Height="440" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F7F1EE">
    <StackPanel Margin="32" VerticalAlignment="Center">
        <TextBlock Text="Cave du Sommelier" FontSize="22" FontWeight="Bold"
                   Foreground="#7A1F2B" Margin="0,0,0,24" HorizontalAlignment="Center"/>

        <TextBlock Text="Email" Margin="0,0,0,4"/>
        <TextBox x:Name="ChampEmail" Padding="6" Margin="0,0,0,14"/>

        <TextBlock Text="Mot de passe" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ChampMotDePasse" Padding="6" Margin="0,0,0,10"/>

        <TextBlock x:Name="TexteMessage" Foreground="Crimson" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Button Content="Se connecter" Padding="10,8" Background="#7A1F2B" Foreground="White"
                BorderThickness="0" Click="BoutonConnexion_Click" Margin="0,0,0,14"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Créer un compte" Click="BoutonCreerCompte_Click"
                    Background="Transparent" Foreground="#7A1F2B" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text=" · " VerticalAlignment="Center"/>
            <Button Content="Mot de passe oublié ?" Click="BoutonMotDePasseOublie_Click"
                    Background="Transparent" Foreground="#7A1F2B" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
