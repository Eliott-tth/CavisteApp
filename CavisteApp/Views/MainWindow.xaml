<Window x:Class="CavisteApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CavisteApp.Views"
        xmlns:services="clr-namespace:CavisteApp.Services"
        Title="Cave du Sommelier" Height="760" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#F7F1EE">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Background="#5C1220" Height="52">
            <TextBlock Text="Cave du Sommelier"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0"/>
            <TextBlock Text="{Binding Source={x:Static services:SessionContext.Instance}, Path=RoleAffiche, StringFormat='Connecté en tant que : {0}'}"
                       Foreground="#E8C9CD" FontSize="12" VerticalAlignment="Center" Margin="24,0,0,0"/>
            <TextBlock Text="{Binding Source={x:Static services:SessionContext.Instance}, Path=UtilisateurConnecte.Email}"
                       Foreground="#E8C9CD" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <TabControl x:Name="OngletsPrincipaux" Grid.Row="1" TabStripPlacement="Left">
            <TabItem Header="Accueil">
                <Border Padding="20">
                    <views:AccueilView/>
                </Border>
            </TabItem>
            <TabItem Header="Tableau de bord">
                <Border Padding="20">
                    <views:TableauDeBordView/>
                </Border>
            </TabItem>
            <TabItem Header="Vente">
                <Border Padding="20">
                    <views:VenteView/>
                </Border>
            </TabItem>
            <TabItem Header="Stock">
                <Border Padding="20">
                    <views:VinListView/>
                </Border>
            </TabItem>
            <TabItem Header="Clients">
                <Border Padding="20">
                    <views:ClientListView/>
                </Border>
            </TabItem>
            <TabItem Header="Fournisseurs"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <Border Padding="20">
                    <views:FournisseurListView/>
                </Border>
            </TabItem>
            <TabItem Header="Alertes &amp; Commandes"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <Border Padding="20">
                    <views:AlerteCommandeView/>
                </Border>
            </TabItem>
            <TabItem Header="Génération"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <Border Padding="20">
                    <views:GenerationView/>
                </Border>
            </TabItem>
            <TabItem Header="Utilisateurs"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <Border Padding="20">
                    <views:UtilisateurListView/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
