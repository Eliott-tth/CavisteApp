<Window x:Class="CavisteApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CavisteApp.Views"
        xmlns:services="clr-namespace:CavisteApp.Services"
        Title="Caviste - Logiciel de caisse" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Background="#2C2A28" Height="48">
            <TextBlock Text="Caviste"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="16,0"/>
            <TextBlock Text="{Binding Source={x:Static services:SessionContext.Instance}, Path=RoleAffiche, StringFormat='Connecté en tant que : {0}'}"
                       Foreground="LightGray" FontSize="12" VerticalAlignment="Center" Margin="24,0,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="12">
            <TabItem Header="Vente">
                <views:VenteView/>
            </TabItem>
            <TabItem Header="Stock">
                <views:VinListView/>
            </TabItem>
            <TabItem Header="Clients">
                <views:ClientListView/>
            </TabItem>
            <TabItem Header="Fournisseurs"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <views:FournisseurListView/>
            </TabItem>
            <TabItem Header="Alertes &amp; Commandes"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <views:AlerteCommandeView/>
            </TabItem>
            <TabItem Header="Génération"
                     Visibility="{Binding Source={x:Static services:SessionContext.Instance}, Path=EstAdministrateur, Converter={StaticResource BoolToVis}}">
                <views:GenerationView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
