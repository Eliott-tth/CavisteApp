<UserControl x:Class="CavisteApp.Views.FournisseurListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CavisteApp.ViewModels">

    <UserControl.DataContext>
        <vm:FournisseurListViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Fournisseurs" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Nouveau" Command="{Binding NouveauCommand}" Margin="16,0,0,0" Padding="10,4"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding MessageStatut}" Margin="0,8,0,0" Foreground="DimGray"/>

            <DataGrid ItemsSource="{Binding Fournisseurs}" SelectedItem="{Binding FournisseurSelectionne}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120"/>
                    <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="16" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Fiche fournisseur" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="Nom"/>
                <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Email"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Téléphone"/>
                <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Adresse"/>
                <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,2,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Enregistrer" Command="{Binding EnregistrerCommand}" Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="Supprimer" Command="{Binding SupprimerCommand}" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>