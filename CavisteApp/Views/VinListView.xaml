<UserControl x:Class="CavisteApp.Views.VinListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CavisteApp.ViewModels"
             xmlns:conv="clr-namespace:CavisteApp.Converters">

    <UserControl.Resources>
        <conv:BoolToAlertBrushConverter x:Key="AlertBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:VinListViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Liste des vins -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Stock de vins" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Nouveau" Command="{Binding NouveauCommand}" Margin="16,0,0,0" Padding="10,4"/>
                <Button Content="Importer depuis l'API" Command="{Binding ImporterDepuisApiCommand}"
                        Margin="8,0,0,0" Padding="10,4" IsEnabled="{Binding ImportEnCours, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding MessageStatut}" Margin="0,8,0,0" Foreground="DimGray"/>

            <DataGrid ItemsSource="{Binding Vins}" SelectedItem="{Binding VinSelectionne}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Alerte" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="14" Height="14"
                                         Fill="{Binding EstEnAlerte, Converter={StaticResource AlertBrushConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                    <DataGridTextColumn Header="Prix (€)" Binding="{Binding Prix, StringFormat={}{0:N2}}" Width="90"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="70"/>
                    <DataGridTextColumn Header="Seuil bas" Binding="{Binding SeuilBas}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Formulaire d'édition -->
        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="16" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Fiche vin" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="Nom"/>
                <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Type"/>
                <ComboBox ItemsSource="{Binding TypesDisponibles}" SelectedItem="{Binding TypeSelectionne}" Margin="0,2,0,10"/>

                <TextBlock Text="Prix (€)"/>
                <TextBox Text="{Binding Prix, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Stock"/>
                <TextBox Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10"/>

                <TextBlock Text="Seuil de stock bas"/>
                <TextBox Text="{Binding SeuilBas, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,16"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Enregistrer" Command="{Binding EnregistrerCommand}" Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="Supprimer" Command="{Binding SupprimerCommand}" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
